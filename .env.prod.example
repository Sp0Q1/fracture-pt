# GetHacked.eu — Production environment
# Copy to .env.prod and fill in all values.
# NEVER commit .env.prod to version control.

# --- Domains ---
APP_DOMAIN=gethacked.eu
ZITADEL_DOMAIN=auth.gethacked.eu

# --- Application secrets ---
JWT_SECRET=        # openssl rand -base64 32
OIDC_CLIENT_ID=    # from Zitadel after setup
OIDC_CLIENT_SECRET=# from Zitadel after setup
OIDC_PROJECT_ID=   # from Zitadel after setup

# --- Application database (PostgreSQL) ---
APP_DB_USER=gethacked
APP_DB_PASSWORD=   # openssl rand -base64 24
APP_DB_NAME=gethacked

# --- Zitadel database ---
ZITADEL_DB_POSTGRES_PASSWORD=  # openssl rand -base64 24
ZITADEL_DB_ZITADEL_PASSWORD=   # openssl rand -base64 24
ZITADEL_MASTERKEY=             # openssl rand -hex 16 (must be exactly 32 hex chars)

# --- SMTP (for both Zitadel and the app) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAILER_HOST=smtp.example.com
MAILER_PORT=587
MAILER_USER=
MAILER_PASSWORD=

# --- Ports (local, behind nginx) ---
APP_PORT=5150
ZITADEL_PORT=8081
